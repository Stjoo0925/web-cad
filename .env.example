# =============================================================================
# Web CAD 온프렘 환경변수 설정
# =============================================================================
# 사용법:
#   cp .env.example .env
#   .env 파일을 편집하여 필요한 값을 설정
#   docker-compose up -d

# =============================================================================
# JWT 인증
# =============================================================================
WEB_CAD_JWT_SECRET=change-me-with-64-char-random-string
WEB_CAD_JWT_ISSUER=web-cad-onprem

# =============================================================================
# 스토리지
# =============================================================================
# 호스트 머신의 스토리지 경로
WEB_CAD_STORAGE_ROOT_HOST=./data
# 컨테이너 내 스토리지 경로 (변경不建议)
WEB_CAD_STORAGE_ROOT_CONTAINER=/app/storage

# =============================================================================
# 데이터베이스 (PostgreSQL)
# =============================================================================
WEB_CAD_DB_HOST=db
WEB_CAD_DB_PORT=5432
WEB_CAD_DB_USER=postgres
WEB_CAD_DB_PASSWORD=change-me-with-strong-password
WEB_CAD_DB_NAME=webcad

# =============================================================================
# 포트 설정
# =============================================================================
WEB_CAD_API_PORT=4010
WEB_CAD_FILES_PORT=4011
WEB_CAD_HEALTH_PORT=4012

# =============================================================================
# 개발/디버그
# =============================================================================
NODE_ENV=production
